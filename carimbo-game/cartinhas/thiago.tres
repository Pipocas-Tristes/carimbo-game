[resource]
script = ExtResource("1_mup0q")
content = "Olá Papai Noel, tudo bem com o senhor? Um dia papai saiu de casa, sem nem me dar tchau, e mamãe disse que ele foi procurar uma coisa importante e deve ter se perdido no caminho. Desde então, a mamãe trabalha muito mais do que antes, e eu fico muito tempo sozinho.  Tenho saudade de jogar bola com o papai aos fins de semana. Papai Noel, para este natal eu não quero nenhum brinquedo caro, só quero meu papai de volta. Mamãe vai trabalhar na noite de Natal e eu estarei sozinho em casa, esperarei o senhor perto da árvore.
Ass.: Thiago.
"
is_suspicious = true
texture = ExtResource("2_1yh8i")
sender_name = "Thiago"
metadata/_custom_type_script = "uid://1oycgv6x3g7y"
