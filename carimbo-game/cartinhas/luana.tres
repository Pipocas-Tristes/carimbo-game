[resource]
script = ExtResource("1_sso0d")
content = "Papai Noel, ontem meu peixinho de estimacaum dormiu de ponta cabeça e o papai jogou ele na privada. Eu chorei muito mas passo. Voce podia pegar ele embalar no presente e mandar de volta? Nao vai custar dinheiro."
