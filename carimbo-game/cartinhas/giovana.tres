[resource]
script = ExtResource("1_t5wny")
content = "Papai Noel, algumas meninas me disseram que não vou ganhar presentes esse ano por ser uma menina má. Não acredito que isso seja verdade. Todas as aulas que eu mato são chatas, todas as pessoas que eu “ofendo” merecem isso, e todas as vezes que eu menti pros meus pais eu tive meus motivos. Não sou má, eu apenas fasso o que eu quero fazer. Neste Natal, quero brincos de ouro
-Giovana"
correct_stamp = "coal"
texture = ExtResource("2_rjg8k")
metadata/_custom_type_script = "uid://1oycgv6x3g7y"
