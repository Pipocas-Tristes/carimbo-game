[resource]
script = ExtResource("1_qfof8")
content = "Papai noel desculpa por aquela vez que eu puxei o cabelo da Milena na escola fiquei bravo porque ela me chamou de cara de pastel. Espero que eu não esteja na lista de meninas maus. Te amo papai noel. Quero uma fantasia do homem aranha"
