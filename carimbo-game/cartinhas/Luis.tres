[resource]
script = ExtResource("1_fm7h4")
content = "qUERIdo, papai, Noel. Eu sempre fui bonzinho, minha vó, disse que eu sou menino gentil e carinhoso. Uma ves so eu pisei no inseto do meu amigo joao mas foi sem querer e porque ele me deixou bravo. Se voce tiver presente eu peço desculpa ta bom. Eu quero uma cozinha de brinquedo."
texture = ExtResource("2_exq26")
