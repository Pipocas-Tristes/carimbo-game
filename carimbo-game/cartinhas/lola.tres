[resource]
script = ExtResource("1_k8c1d")
content = "Papai Noel, espero por você mais um ano ! deixei leite e biscoitos (com gotas de chocolate) perto da lareira. Tenho sido uma boa menina e sempre ajudo papai e mamãe com as tarefas de casa e vou muito bem na escola. Sou muito grata por ter uma casa confortável e muitos brinquedos, mas tem algo que eu gostaria muito neste natal: um cachorrinho.
Com amor, Lola"
texture = ExtResource("2_12jig")
sender_name = "Lola"
metadata/_custom_type_script = "uid://1oycgv6x3g7y"
