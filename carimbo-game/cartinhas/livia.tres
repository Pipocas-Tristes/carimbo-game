[resource]
script = ExtResource("1_pt40j")
content = "A carta apresenta palavras em uma letra bem ilegível. É visível que a criança se empenhou para escrever, mas ainda não sabe como. Abaixo do indecifrável, existe um desenho feito de giz de cera. Ainda que meio torta e com traços difíceis de compreender, parecia uma casa. Talvez uma casa de bonecas?"
texture = ExtResource("2_heo7d")
sender_name = "Lívia"
